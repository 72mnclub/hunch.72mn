---
const features = [
  {
    n: '01',
    h: 'Your vault is .md files.',
    body: 'Every journal is plain markdown on disk. Vault is portable to Obsidian, syncs across devices via iCloud, Dropbox or git.',
    tail: 'The file is the source of truth; the app is one view onto it.',
  },
  {
    n: '02',
    h: 'Multi-account trade sync.',
    body: 'Connect one or more IBKR Flex accounts. Trades land as JSONL inside the vault; the per-device SQLite index is rebuildable.',
    tail: 'Switching vaults swaps the whole second brain.',
  },
  {
    n: '03',
    h: 'A four-layer journal model.',
    body: 'Meta, subjective, objective, and AI sections — kept on disk in frontmatter and ## sections.',
    tail: 'Structured where structure helps; free-style everywhere else.',
  },
  {
    n: '04',
    h: 'Live preview that gets out of the way.',
    body: 'Obsidian-style editor: inline syntax markers hide outside the caret line, slash menu for blocks, typed-link chips for tickers and trades.',
    tail: 'Read surface and edit surface match.',
  },
];
---

<section id="features" class="features">
  <div class="features-grid">
    <aside class="features-side">
      <div class="kicker features-kicker">What's inside</div>
      <h2 class="features-h2">Four ideas, one app.</h2>
      <div class="rule-accent features-rule"></div>
      <p class="lede dim features-lede">
        Minimal where it matters. The defaults are chosen so you can ship
        your first journal entry in under a minute.
      </p>
    </aside>

    <div class="features-cards">
      {features.map((f, i) => (
        <article class={`features-card ${i % 2 === 1 ? 'right' : 'left'}`}>
          <div class="mono features-n">{f.n}</div>
          <h3 class="features-card-h">{f.h}</h3>
          <p class="features-card-body">
            {f.body}{' '}
            <span class="mut">{f.tail}</span>
          </p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: 8px 56px 88px;
    border-top: 1px solid var(--hair);
  }

  .features-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 64px;
    padding-top: 48px;
  }

  .features-side {
    position: sticky;
    top: 24px;
    align-self: start;
  }

  .features-kicker {
    margin-bottom: 12px;
  }

  .features-h2 {
    font-size: 32px;
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.1;
  }

  .features-rule {
    margin-top: 20px;
  }

  .features-lede {
    font-size: 14px;
    margin-top: 20px;
  }

  .features-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .features-card {
    padding: 28px 28px 32px;
    border-top: 1px solid var(--hair);
  }

  .features-card.right {
    border-left: 1px solid var(--hair);
  }

  .features-n {
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 14px;
  }

  .features-card-h {
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.25;
    margin: 0 0 10px;
  }

  .features-card-body {
    font-size: 14px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0;
  }

  .features-card-body .mut {
    color: var(--muted);
  }

  @media (max-width: 1024px) {
    .features { padding: 8px 32px 64px; }
    .features-grid { grid-template-columns: 1fr; gap: 32px; padding-top: 32px; }
    .features-side { position: static; }
  }

  @media (max-width: 640px) {
    .features { padding: 8px 20px 48px; }
    .features-cards { grid-template-columns: 1fr; }
    .features-card.right { border-left: none; }
  }
</style>
