---
import Wordmark from './Wordmark.astro';

const HUNCH_INTRO = "A local-first Mac app for trading journals and a personal knowledge base — an Obsidian-style markdown vault with structured templates, broker-synced trades, and (post-MVP) LLM personas.";
---

<header class="masthead">
  <div class="masthead-top">
    <a href="https://72mn.com" aria-label="72mn home"><Wordmark /></a>
    <span class="mono masthead-vol">Vol I · hunch.72mn.com</span>
    <nav class="nav-r masthead-nav">
      <a href="#features">Features</a>
      <a href="#access">Private beta</a>
    </nav>
  </div>

  <div class="masthead-h1-row">
    <h1 class="masthead-h1">
      Trader&nbsp;Brain<span class="accent-dot">.</span>
    </h1>
    <div class="masthead-intro">
      <div class="kicker masthead-kicker">A product by 72mn · Private beta</div>
      <p class="masthead-lede">{HUNCH_INTRO}</p>
    </div>
  </div>
</header>

<style>
  .masthead {
    padding: 32px 56px 24px;
    border-bottom: 2px solid var(--ink);
  }

  .masthead-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 24px;
  }

  .masthead-vol {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .masthead-nav {
    display: flex;
    gap: 28px;
    align-items: center;
    font-size: 13px;
    color: var(--muted);
  }
  .masthead-nav a:hover { color: var(--ink); }

  .masthead-h1-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-top: 36px;
    gap: 40px;
  }

  .masthead-h1 {
    font-size: 144px;
    line-height: 0.88;
    letter-spacing: -0.04em;
    font-weight: 500;
    margin: 0;
  }

  .accent-dot {
    color: var(--accent);
  }

  .masthead-intro {
    max-width: 380px;
    padding-bottom: 12px;
  }

  .masthead-kicker {
    margin-bottom: 10px;
  }

  .masthead-lede {
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .masthead { padding: 28px 32px 20px; }
    .masthead-h1 { font-size: 96px; }
    .masthead-h1-row { flex-direction: column; align-items: flex-start; gap: 24px; }
  }

  @media (max-width: 640px) {
    .masthead { padding: 24px 20px 16px; }
    .masthead-top { flex-wrap: wrap; gap: 14px; }
    .masthead-vol { order: 3; flex-basis: 100%; }
    .masthead-h1 { font-size: 64px; }
  }
</style>
